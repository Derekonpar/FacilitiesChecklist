# Supabase (https://supabase.com/dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
# Use either legacy anon key OR new publishable key (sb_publishable_…)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Optional aliases (server reads these too)
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_PROJECT_ID=
# Optional: personal access token for npm run disable:email-confirm
# https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=
# Server-only — required for manager updates & team permissions API
SUPABASE_SERVICE_ROLE_KEY=
# Or new secret key name from Supabase dashboard
SUPABASE_SECRET_KEY=

# Auth: enable Email in Supabase → Authentication → Providers
# Disable "Confirm email" for instant staff sign-up (recommended)
# Run supabase/migrations/004_auth_profiles.sql in SQL Editor
# Optional one-time: DEREK_INITIAL_PIN=123456 then npm run bootstrap:admin
# Supabase Auth → set minimum password length to 6 for PINs
