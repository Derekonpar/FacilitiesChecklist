# Supabase (https://supabase.com/dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
# Use either legacy anon key OR new publishable key (sb_publishable_…)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Optional aliases (server reads these too)
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_PROJECT_ID=
# Server-only — required for manager Complete / Recall
SUPABASE_SERVICE_ROLE_KEY=
# Or new secret key name from Supabase dashboard
SUPABASE_SECRET_KEY=

# Shared PIN for managers (/lead) — server-side only
MANAGER_PIN=
